  "layer": [
    {
      "mark": {
        "type": "circle",
        "cursor": "pointer"
      },
      "encoding": {
        "x": {
          "field": "trait",
          "type": "nominal",
          "sort": {
            "field": "trait_order"
          },
          "axis": {
            "title": null,
            "orient": "top",
            "labelFontSize": 9.5,
            "labelFontWeight": 700,
            "labelColor": "#2B1F12",
            "labelAngle": 0,
            "domain": false,
            "ticks": false,
            "labelPadding": 8,
            "labelLimit": 80
          },
          "scale": {
            "paddingInner": 0.1,
            "paddingOuter": 0.2
          }
        },
        "y": {
          "field": "common_name",
          "type": "nominal",
          "sort": [
            "Platypus",
            "Koala",
            "Eastern Grey Kangaroo",
            "Emu",
            "Red Kangaroo"
          ],
          "axis": {
            "title": null,
            "labelFontSize": 9,
            "labelFontWeight": 600,
            "labelColor": "#2B1F12",
            "domain": false,
            "ticks": false,
            "labelPadding": 6,
            "labelLimit": 110
          }
        },
        "size": {
          "field": "norm",
          "type": "quantitative",
          "scale": {
            "range": [
              40,
              900
            ]
          },
          "legend": null
        },
        "color": {
          "field": "common_name",
          "type": "nominal",
          "scale": {
            "domain": [
              "Red Kangaroo",
              "Eastern Grey Kangaroo",
              "Koala",
              "Emu",
              "Platypus"
            ],
            "range": [
              "#B85450",
              "#8B8378",
              "#4878A8",
              "#C8923D",
              "#4A6670"
            ]
          },
          "legend": null
        },
        "opacity": {
          "condition": [
            {
              "param": "sp_click4",
              "empty": false,
              "value": 0.92
            },
            {
              "param": "sp_hover4",
              "empty": false,
              "value": 0.92
            }
          ],
          "value": 0.82
        },
        "stroke": {
          "condition": [
            {
              "param": "sp_hover4",
              "empty": false,
              "value": "#2B1F12"
            },
            {
              "param": "sp_click4",
              "empty": false,
              "value": "#2B1F12"
            }
          ],
          "value": "white"
        },
        "strokeWidth": {
          "condition": [
            {
              "param": "sp_hover4",
              "empty": false,
              "value": 1.5
            },
            {
              "param": "sp_click4",
              "empty": false,
              "value": 1.5
            }
          ],
          "value": 0.5
        },
        "tooltip": [
          {
            "field": "common_name",
            "type": "nominal",
            "title": "Species"
          },
          {
            "field": "trait",
            "type": "nominal",
            "title": "Trait"
          },
          {
            "field": "value_label",
            "type": "nominal",
            "title": "Value"
          }
        ]
      },
      "params": [
        {
          "name": "sp_click4",
          "select": {
            "type": "point",
            "fields": [
              "common_name"
            ],
            "on": "click",
            "clear": "dblclick"
          }
        },
        {
          "name": "sp_hover4",
          "select": {
            "type": "point",
            "fields": [
              "common_name"
            ],
            "on": "mouseover",
            "clear": "mouseout"
          }
        }
      ]
    },
    {
      "transform": [
        {
          "filter": "datum.norm > 0.3"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 8.5,
        "fontWeight": 700,
        "color": "white"
      },
      "encoding": {
        "x": {
          "field": "trait",
          "type": "nominal",
          "sort": {
            "field": "trait_order"
          },
          "axis": {
            "labelFontSize": 9.5,
            "labelLimit": 80
          },
          "scale": {
            "paddingInner": 0.1,
            "paddingOuter": 0.2
          }
        },
        "y": {
          "field": "common_name",
          "type": "nominal",
          "sort": [
            "Platypus",
            "Koala",
            "Eastern Grey Kangaroo",
            "Emu",
            "Red Kangaroo"
          ]
        },
        "text": {
          "field": "value_label",
          "type": "nominal"
        },
        "opacity": {
          "condition": [
            {
              "param": "sp_click4",
              "empty": false,
              "value": 1
            },
            {
              "param": "sp_hover4",
              "empty": false,
              "value": 1
            }
          ],
          "value": 0.82
        }
      }
    }
  ],
  "width": {
    "step": 68
  }
}